# ===================================
# RBAC RAG System - Environment Variables
# ===================================
# Copy this file to .env and fill in your actual values

# Groq API Key (REQUIRED)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# LLM Model Configuration
# Default: openai/gpt-oss-20b
LLM_MODEL=openai/gpt-oss-20b

# Embedding Model Configuration
# Default: sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Backend URL for frontend communication
# For Docker: http://backend:8000 (internal)
# For local dev: http://localhost:8000
BACKEND_URL=http://localhost:8000

# CORS Allowed Origins (comma-separated)
# For Docker: http://frontend:8501
# For local dev: http://localhost:8501
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ===================================
# Rate Limiting Configuration
# ===================================
# Groq free tier limits: ~30 requests/minute
# Adjust based on your API tier

# Requests per minute limit
# Free tier: 25 (default), Pro: 120+
RATE_LIMIT_RPM=25

# Request timeout in seconds (default: 120)
# Increase if queries are complex
REQUEST_TIMEOUT=120

# Maximum retry attempts for failed requests
# Default: 3 (exponential backoff applies)
MAX_RETRIES=3

# Initial retry delay in seconds
# Default: 10 (increases exponentially)
RETRY_DELAY=10

# ===================================
# Data Configuration
# ===================================
# DATADIR=data
# FAISS_INDEX=Faiss-Vectors

# ===================================
# Production Settings (Optional)
# ===================================
# LOG_LEVEL=INFO
# WORKERS=4
